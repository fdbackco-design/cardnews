# 질병관리청 국가건강정보포털
KDCA_BASE_URL=https://health.kdca.go.kr/healthinfo/biz/health/gnrlzHealthInfo/gnrlzHealthInfo/gnrlzHealthInfoView.do

# ── 이미지 공급자 ─────────────────────────────────────────────────────────────
# hybrid  : Gemini/Imagen → Pexels → local fallback (기본값)
# gemini  : Gemini/Imagen → Pexels → local
# pexels  : Pexels → local
# local   : local fallback만 사용
IMAGE_PROVIDER=hybrid

# Gemini / Imagen 이미지 생성 (IMAGE_PROVIDER=hybrid 또는 gemini 시 사용)
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# 카드 본문 재작성 (KDCA 원문 → intro/highlights/outro)
# off  : LLM 미사용, rule fallback만
# rule : LLM 미사용 (명시)
# (기본) GEMINI_API_KEY가 있으면 LLM 재작성
CONTENT_GENERATOR=
CONTENT_GENERATOR_MODEL=gemini-1.5-flash

# 이미지 생성 모델 (기본값: gemini-2.5-flash-image)
# gemini-2.5-flash-image  : Google AI Studio 기본 — 안정적으로 작동
# imagen-4.0-generate-001 : Imagen 4 (Google AI Studio 접근 가능, aspectRatio 3:4 사용)
# imagen-4.0-ultra-generate-001 : Imagen 4 Ultra (Vertex AI 전용일 수 있음)
IMAGE_GENERATION_MODEL=gemini-2.5-flash-image
IMAGEN_MODEL=imagen-4.0-generate-001

# 이미 생성된 이미지를 무시하고 강제 재생성 (기본값: false)
FORCE_REGENERATE_IMAGES=false

# Pexels API (Imagen 실패 시 fallback)
# 발급: https://www.pexels.com/api/
PEXELS_API_KEY=

# Google Custom Search API (레거시 — 현재 비활성화)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# 출력 설정
OUTPUT_DIR=./output
OUTPUT_SCALE=2

# daily batch — 이미 제작한 KDCA contentId 이력
# 예시: data/processed-content.example.json
PROCESSED_REGISTRY_PATH=./data/processed-content.json

# daily batch — 목록 탐색 최대 페이지 수
DAILY_MAX_PAGES=6

# ── Instagram Graph API (Carousel 자동 업로드) ────────────────────────────────
# 발급: Meta Business Suite → 시스템 사용자 액세스 토큰 (instagram_content_publish 권한 필요)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_GRAPH_API_VERSION=v25.0

# ── 공개 이미지 저장소 (Instagram Graph API용) ────────────────────────────────
# Instagram은 로컬 PNG 파일을 직접 업로드할 수 없다.
# 공개적으로 접근 가능한 HTTPS URL을 먼저 만든 뒤 그 URL을 Graph API에 전달해야 한다.
#
# local-placeholder : 미설정 — 업로드를 차단 (안전 기본값)
# r2                : Cloudflare R2 (S3 호환) — 향후 구현
# s3                : AWS S3 — 향후 구현
PUBLIC_ASSET_PROVIDER=local-placeholder

# Cloudflare R2 (PUBLIC_ASSET_PROVIDER=r2 일 때 사용)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ── 관리 웹앱 ─────────────────────────────────────────────────────────────────
# 로컬 개발: WEB_PORT=3000 → http://localhost:3000
# NAS 배포: 컨테이너 내부 WEB_PORT=3000, 외부 접속 포트는 3100 (docker-compose 포트 매핑)
WEB_PORT=3000

# NAS Docker 배포 시 출력 경로 (컨테이너 내부 경로)
# 로컬 개발 시: OUTPUT_DIR=./output
# NAS 배포 시:  OUTPUT_DIR=/app/output  (docker-compose volume에 의해 NAS에 영구 저장)
OUTPUT_DIR=./output
