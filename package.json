{
  "name": "cardnews-generator",
  "version": "1.0.0",
  "description": "TY Life Partners 라이프 가이드 카드뉴스 자동 생성 시스템",
  "main": "dist/index.js",
  "scripts": {
    "generate": "tsx src/index.ts",
    "capture": "tsx src/generator/captureCards.ts",
    "all": "npm run generate -- --capture",
    "build": "tsc && cp -r src/web/public dist/web/public && cp -r src/templates dist/templates",
    "start": "node dist/web/server.js",
    "dev": "tsx watch src/index.ts",
    "kdca:list": "tsx src/services/kdcaListScraper.ts",
    "daily": "tsx src/jobs/dailyCardNews.ts",
    "daily:dry-run": "tsx src/jobs/dailyCardNews.ts --dry-run",
    "web": "tsx watch src/web/server.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@types/sharp": "^0.31.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "playwright": "^1.44.0",
    "sharp": "^0.34.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
